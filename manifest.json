{
  "manifest_version": 3,
  "name": "Markdown Viewer",
  "version": "1.0.0",
  "description": "Preview markdown files in your browser. Opens local .md files with a table of contents—nothing is uploaded, synced, or tracked.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Markdown Viewer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "docs/*.md",
        "vendor/*.js",
        "styles.css",
        "app.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
